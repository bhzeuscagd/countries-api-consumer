---
import { Image } from "astro:assets";
import { createSlug } from "../utils/countries";

export interface Props {
    name: string;
    population: string;
    region: string;
    capital: string;
    flagUrl: string;
}

const { name, population, region, capital, flagUrl } = Astro.props;
const slug = createSlug(name);
---

<a
    href={`/${slug}`}
    class="block h-full outline-none focus-visible:ring-4 focus-visible:ring-blue-500 rounded-md"
>
    <article
        class="flex flex-col gap-4 rounded-md shadow-[0_0_10px_rgba(0,0,0,0.1)] dark:shadow-none bg-white dark:bg-blue-900 cursor-pointer hover:scale-105 transition-transform duration-200 overflow-hidden country-card h-full"
        data-region={region}
        data-name={name.toLowerCase()}
    >
        <!-- object-cover with a fixed aspect ratio guarantees uniform image sizes -->
        <Image
            src={flagUrl}
            alt={`Flag of ${name}`}
            width={320}
            height={215}
            class="w-full aspect-3/2 object-cover"
        />

        <div class="flex flex-col gap-2 px-6 pb-10 pt-4 grow">
            <h2 class="font-extrabold text-lg py-2 dark:text-white">{name}</h2>
            <p class="text-sm font-semibold dark:text-white">
                Population: <span
                    class="font-light text-gray-500 dark:text-gray-300"
                    >{population}</span
                >
            </p>
            <p class="text-sm font-semibold dark:text-white">
                Region: <span
                    class="font-light text-gray-500 dark:text-gray-300"
                    >{region}</span
                >
            </p>
            <p class="text-sm font-semibold dark:text-white">
                Capital: <span
                    class="font-light text-gray-500 dark:text-gray-300"
                    >{capital}</span
                >
            </p>
        </div>
    </article>
</a>
